# ──────────────────────────────────────────────
# Large intermediate geodata (regenerated by ETL)
# We commit only the final simplified TopoJSON files.
# Raw GeoJSON, intermediate projections, and unsimplified
# municipality GeoJSON are too large for git (10-110 MB each).
# ──────────────────────────────────────────────
data/geo/*-raw.geojson
data/geo/*-4326.geojson
data/geo/denmark-municipalities.geo.json
data/dawa/kommuner.geojson

# WFS capability/layer listings (debug artifacts)
data/geo/*-capabilities.xml
data/geo/*-layers.txt
data/geo/layers-*.txt

# ETL debug/batch artifacts
data/mars/plans_batch1.json
data/dashboard-data-debug.json

# Empty directory placeholder
data/miljogis/

# Research transcripts (large, personal, not part of the product)
transcripts_and_research/

# OS files
.DS_Store
Thumbs.db

