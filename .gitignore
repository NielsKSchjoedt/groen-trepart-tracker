# ──────────────────────────────────────────────
# Large geodata files (too large for git, regenerated by ETL)
# Rule: ignore full-geometry datasets above ~2 MB.
# Keep: samples (_sample suffix), small full datasets (< 2 MB),
#       and all files under public/data/ (production output).
# ──────────────────────────────────────────────
data/geo/*-raw.geojson
data/geo/*-4326.geojson
data/geo/denmark-municipalities.geo.json
data/dawa/kommuner.geojson

# WFS capability/layer listings (debug artifacts)
data/geo/*-capabilities.xml
data/geo/*-layers.txt
data/geo/layers-*.txt

# ETL debug/batch artifacts
data/mars/plans_batch1.json
data/dashboard-data-debug.json
data/geo-kommune-cache.json

# ──────────────────────────────────────────────
# Large raw ETL intermediates (regenerated by fetch scripts,
# not served to users — processed versions live in public/data/)
# ──────────────────────────────────────────────
# geometries-wkt.json: internal MARS geometry cache (6500 individual API
# calls to regenerate, 70 MB) — implementation detail, not a data source
data/mars/geometries-wkt.json

# Empty directory placeholder
data/miljogis/

# Research transcripts (large, personal, not part of the product)
transcripts_and_research/

# OS files
.DS_Store
Thumbs.db

# IDE / Editor
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~

# Environment
.env
.env.local

# Cursor
.cursor/

# Playwright (local test runs)
test-results/
playwright-report/
